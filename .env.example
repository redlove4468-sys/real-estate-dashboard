# ─────────────────────────────────────────────
# ABC부동산 매물관리 대시보드 — 환경변수 설정 예시
# 실제 값은 .env 파일을 새로 만들어서 채워넣으세요 (.env는 절대 GitHub에 올리지 마세요)
# ─────────────────────────────────────────────

# [필수] 데이터베이스 연결 주소
# Railway → MySQL 서비스 → Variables 탭 → MYSQL_URL 또는 DATABASE_URL 값을 복사
# 형식: mysql://사용자명:비밀번호@호스트:포트/DB이름
DATABASE_URL=mysql://user:password@host:port/database

# [필수] 로그인 세션 암호화 키 (아무 긴 임의 문자열, 외부에 노출되면 안 됨)
# 터미널에서 만들고 싶으면: openssl rand -base64 32
JWT_SECRET=여기에-긴-임의-문자열-입력

# [필수] 최초 관리자 계정을 만들 때 사용하는 보안 키 (1회용, setupMaster API 호출 시 필요)
MASTER_SETUP_KEY=원하는-임의-문자열

# [필수] 사진 저장용 AWS S3 버킷 이름
S3_BUCKET=abc-realestate-photos

# [선택] S3 버킷 리전 (기본값: ap-northeast-2, 서울 리전)
S3_REGION=ap-northeast-2

# [필수] AWS 자격증명 (S3 업로드/다운로드용)
# AWS IAM에서 발급받은 Access Key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# [정보용, 코드에서 더는 사용 안 함] 과거 Manus 전용 변수 — 삭제해도 무방
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# 서버 포트 (Railway/Netlify가 자동으로 설정해주므로 보통 안 건드려도 됨)
PORT=3000
NODE_ENV=production
